+
+    dev->private = ctrl_block_init(WIN_BUFF_NUM, WIN_BUFF_SIZE, WIN_BUFF_NUM, WIN_BUFF_SIZE);
+    return 0;
 }
 
 void
 tuntap_release(struct device *dev) {
 	(void)CloseHandle(dev->tun_fd);
-	free(dev);
+    ctrl_block_destory(dev->private);
+    free(dev);
 }
 
